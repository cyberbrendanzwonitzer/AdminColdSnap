# CryoChamber Admin Dashboard Configuration

# Port to run the admin dashboard on
PORT=3001

# CORS origin (allow requests from)
CORS_ORIGIN=*

# Main API base URL (where the CryoChamber booking API is running)
# Local development example:
MAIN_API_BASE=http://localhost:3000
# Hosted deployment example:
# MAIN_API_BASE=https://your-main-api.up.railway.app

# Enable mock data for testing (without connecting to main API)
ENABLE_MOCK_DATA=false
